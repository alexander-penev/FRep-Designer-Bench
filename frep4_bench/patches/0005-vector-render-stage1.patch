diff --git a/core/compiler/codegen.cpp b/core/compiler/codegen.cpp
index 82bd26a..1b6cb9a 100644
--- a/core/compiler/codegen.cpp
+++ b/core/compiler/codegen.cpp
@@ -2827,6 +2827,182 @@ llvm::Function* SceneCodegen::emit_render_tile(const SceneGraph& scene,
     return emit_tracer(scene, sdf_fn, normal_fn, shader_fn, mat_fn);
