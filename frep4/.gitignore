# Build output
build/
out/
smoke/
gallery/
*.o
*.obj
*.a
*.so
*.dylib
*.dll

# Generated by tools at runtime
*.ppm
*.spv
/tmp/frep_glsl_*

# Stray render output. The render tools take the output path as argv[1];
# passing a flag like `--help` to an older build wrote a PPM literally
# named "--help" into the repo root. Those binary blobs have no .ppm
# extension so the rule above misses them — ignore the known offenders
# explicitly. (The tools now recognise --help/-h and won't do this.)
/--help
/-h

# Editor / IDE
.vscode/
.idea/
.cache/
compile_commands.json
*.swp
.DS_Store

# CMake artifacts that may end up in-tree
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Testing/
CTestTestfile.cmake

# Local scratch
scratch/
TODO.local
*.local.md
docs/api/
Doxygen.warnings
